# Server Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# ── Database ────────────────────────────────────────────────────────────────
# Development (Docker Compose + Neon Local):
#   DATABASE_URL=postgres://neon:npg@neon-local:5432/neondb
# Production (Neon Cloud):
#   DATABASE_URL=postgres://neondb_owner:<password>@<host>.neon.tech/neondb?sslmode=require&channel_binding=require
DATABASE_URL=

# ── Neon Local (development only) ──────────────────────────────────────────
# Required when running docker-compose.dev.yml
NEON_API_KEY=
NEON_PROJECT_ID=
# PARENT_BRANCH_ID: ephemeral child branch will be forked from this branch
PARENT_BRANCH_ID=
# Override if Neon Local runs on a different hostname (default: neon-local)
# NEON_LOCAL_HOST=neon-local

# ── Arcjet ──────────────────────────────────────────────────────────────────
# Get your Arcjet key from the Arcjet dashboard
ARCJET_KEY=
